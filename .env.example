# ── Database (Supabase) ────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── PayPal Billing (Live) ─────────────────────────────────────────────
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_SECRET=your_paypal_secret
PAYPAL_MODE=live
PAYPAL_WEBHOOK_ID=WH-xxx

# PayPal Plan IDs (create in PayPal Developer Dashboard)
PAYPAL_PLAN_PRO_MONTHLY=P-xxx
PAYPAL_PLAN_PRO_YEARLY=P-xxx
PAYPAL_PLAN_STUDIO_MONTHLY=P-xxx
PAYPAL_PLAN_STUDIO_YEARLY=P-xxx

# ── iCount (Israeli invoicing — receipts) ─────────────────────────────
ICOUNT_API_TOKEN=your_icount_api_token

# ── AI ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
# BYOK_ENCRYPTION_KEY=xxx  # 32 bytes hex, for encrypting user API keys

# ── CAPTCHA (Cloudflare Turnstile — free, no limit) ───────────────────
# Get keys at: https://dash.cloudflare.com → Turnstile → Create site
TURNSTILE_SECRET_KEY=0x_your_secret_key
VITE_TURNSTILE_SITE_KEY=0x_your_site_key

# ── App ────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
NODE_ENV=development

# ── Frontend (Vite — must be prefixed with VITE_) ─────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
VITE_PAYPAL_CLIENT_ID=your_paypal_client_id

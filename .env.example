# ── App ────────────────────────────────────────────────────────────────
# NODE_ENV=production in fly.io (set automatically via fly.toml)
NODE_ENV=development
APP_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# ── Database (Supabase) ────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key
SUPABASE_ANON_KEY=your_anon_key

# ── PayPal Billing (Live) ─────────────────────────────────────────────
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_SECRET=your_paypal_secret
PAYPAL_MODE=live
PAYPAL_WEBHOOK_ID=your_webhook_id

# PayPal Plan IDs (create via setup script or PayPal Developer Dashboard)
PAYPAL_PLAN_PRO_MONTHLY=P-xxx
PAYPAL_PLAN_PRO_YEARLY=P-xxx
PAYPAL_PLAN_STUDIO_MONTHLY=P-xxx
PAYPAL_PLAN_STUDIO_YEARLY=P-xxx

# ── iCount (Israeli invoicing — receipts for עוסק פטור) ───────────────
ICOUNT_API_TOKEN=your_icount_api_token

# ── AI Providers ──────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# BYOK encryption (32 bytes hex — generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
# REQUIRED in production. Dev mode uses an insecure fallback — NEVER use that fallback in prod.
# WARNING: Once set and users store keys, NEVER change this value — all stored BYOK keys will be unreadable.
BYOK_ENCRYPTION_KEY=

# ── CAPTCHA (Cloudflare Turnstile — free, unlimited) ──────────────────
TURNSTILE_SECRET_KEY=your_turnstile_secret
VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key

# ── Email (Resend — transactional emails) ─────────────────────────────
RESEND_API_KEY=re_your_resend_key
FROM_EMAIL=PackShot Studio <noreply@pack-shot.studio>

# ── Error Monitoring (Sentry — optional, requires `npm install @sentry/node @sentry/react`) ────
# Server DSN (Node project) — captures server errors + unhandled rejections
SENTRY_DSN=
# Browser DSN (React project) — captures frontend errors; baked into bundle at build
VITE_SENTRY_DSN=

# ── Admin Dashboard ───────────────────────────────────────────────────
# Comma-separated list of user UUIDs allowed to access /api/admin/*
# Get your UUID from Supabase → Authentication → Users
ADMIN_USER_IDS=

# ── Frontend (Vite env vars — must be prefixed with VITE_) ────────────
# These are baked into the JS bundle at build time.
# In production: fly secrets set VITE_SUPABASE_URL=... BEFORE fly deploy
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key
VITE_PAYPAL_CLIENT_ID=your_paypal_client_id

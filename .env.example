# ── Database (Supabase) ────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Stripe Billing ─────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe Price IDs (create these in Stripe Dashboard)
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_PRO_YEARLY=price_xxx
STRIPE_PRICE_STUDIO_MONTHLY=price_xxx
STRIPE_PRICE_STUDIO_YEARLY=price_xxx

# Credit packs (Sprint 3)
# STRIPE_PRICE_CREDITS_50=price_xxx
# STRIPE_PRICE_CREDITS_120=price_xxx
# STRIPE_PRICE_CREDITS_300=price_xxx
# STRIPE_PRICE_WATERMARK_REMOVAL=price_xxx

# ── AI ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
# BYOK_ENCRYPTION_KEY=xxx  # 32 bytes hex, for encrypting user API keys (Sprint 3)

# ── CAPTCHA (Cloudflare Turnstile — free, no limit) ───────────────────
# Get keys at: https://dash.cloudflare.com → Turnstile → Create site
TURNSTILE_SECRET_KEY=0x_your_secret_key
VITE_TURNSTILE_SITE_KEY=0x_your_site_key

# ── App ────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
NODE_ENV=development

# ── Frontend (Vite — must be prefixed with VITE_) ─────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
